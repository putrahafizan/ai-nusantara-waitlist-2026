# AI NUSANTARA - Environment Variables Template
# Copy this file to .env.local and fill in your actual values

# ============================================================
# APPLICATION CONFIG
# ============================================================
NODE_ENV=development
APP_NAME=ai-nusantara
APP_URL=http://localhost:3000
API_URL=http://localhost:8000

# ============================================================
# DATABASE CONFIG
# ============================================================
# PostgreSQL Database
DATABASE_URL=postgresql://user:password@localhost:5432/ai_nusantara
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# Vector Database (Qdrant)
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=academic_papers

# Redis Cache
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# ============================================================
# AI MODELS CONFIG
# ============================================================
# Anthropic Claude
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenAI
OPENAI_API_KEY=your_openai_api_key_here

# Google AI (Gemini)
GOOGLE_AI_API_KEY=your_google_ai_api_key_here

# Hugging Face (for open-source models)
HUGGINGFACE_API_KEY=your_huggingface_api_key_here

# ============================================================
# STORAGE CONFIG
# ============================================================
# AWS S3 or Google Cloud Storage
STORAGE_PROVIDER=aws
AWS_REGION=ap-southeast-1
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_S3_BUCKET=ai-nusantara-documents

# ============================================================
# AUTHENTICATION
# ============================================================
# JWT Secret
JWT_SECRET=your_jwt_secret_generate_with_openssl_rand_base64_32
JWT_EXPIRES_IN=7d

# OAuth Providers (optional)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# ============================================================
# EMAIL CONFIG (for notifications)
# ============================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
EMAIL_FROM=noreply@ai-nusantara.id

# ============================================================
# ANALYTICS & MONITORING
# ============================================================
# Google Analytics
GA_MEASUREMENT_ID=

# Sentry (error tracking)
SENTRY_DSN=

# PostHog (product analytics)
POSTHOG_KEY=
POSTHOG_HOST=

# ============================================================
# INDONESIAN-SPECIFIC CONFIG
# ============================================================
# SINTA Integration (Indonesian Research Database)
SINTA_API_URL=https://sinta.kemdikbud.go.id/api
SINTA_API_KEY=

# FORLAP Integration (University Reporting)
FORLAP_API_URL=https://forlap.ristekdikti.go.id/api
FORLAP_API_KEY=

# ============================================================
# RATE LIMITING
# ============================================================
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100

# ============================================================
# FEATURES FLAGS
# ============================================================
FEATURE_LITERATURE_REVIEW=true
FEATURE_CITATION_GENERATOR=true
FEATURE_WRITING_ASSISTANT=true
FEATURE_KNOWLEDGE_GRAPH=false
FEATURE_DATA_ANALYSIS=false
FEATURE_COLLABORATION=false

# ============================================================
# PRICING (in IDR)
# ============================================================
PRICING_DOSEN_PRO_MONTHLY=200000
PRICING_DOSEN_RESEARCHER_MONTHLY=500000
PRICING_UNIVERSITY_PILOT=25000000
PRICING_UNIVERSITY_FACULTY=100000000
PRICING_UNIVERSITY_FULL=300000000
