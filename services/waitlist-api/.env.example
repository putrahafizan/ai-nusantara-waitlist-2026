# AI NUSANTARA - Waitlist API Environment Variables

# Server Configuration
NODE_ENV=development
PORT=3001

# CORS - Allow landing page to call this API
ALLOWED_ORIGINS=http://localhost:8000,http://localhost:3000,https://your-netlify-url.netlify.app

# API Key for stats endpoint (generate random string)
API_KEY=your-secret-api-key-change-this

# Database Configuration
# Option 1: Supabase (Recommended - FREE tier available)
SUPABASE_URL=your-supabase-project-url
SUPABASE_ANON_KEY=your-supabase-anon-key

# Option 2: Local file storage (fallback if no Supabase)
USE_LOCAL_STORAGE=true

# Email Service - Resend (FREE 100 emails/day)
RESEND_API_KEY=your-resend-api-key
FROM_EMAIL=noreply@ai-nusantara.id
FROM_NAME=AI NUSANTARA

# Optional: Analytics
# POSTHOG_KEY=
# GA_MEASUREMENT_ID=
